<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="yin.xuebiblockchain.Mapper.FileUploadMapper">
    <!-- 保存icon   -->
    <update id="save">
        update xuebiChain.user
        set icon = #{url}
        where id = #{userId}
    </update>
</mapper>